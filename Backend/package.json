{
  "name": "bidiichain-backend",
  "version": "1.0.0",
  "description": "BidiiChain / Community Work Tracker - Node.js + Express + MySQL + Sequelize backend",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "db:migrate": "sequelize db:migrate",
