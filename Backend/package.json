    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.19.1",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2"
  }
